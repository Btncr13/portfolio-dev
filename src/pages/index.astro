---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Tecnologia from '../components/Tecnologia.astro';
import ProyectoCard from '../components/ProyectoCard.astro';
import Hero from '../components/Hero.astro';
import SobreMi from '../components/SobreMi.astro';
import Stack from '../components/Stack.astro';

const titulo = "Portfolio | Data Engineer & Web Developer";
---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{titulo}</title>
	</head>
	
	<body class="bg-gray-950 text-gray-50 font-sans p-8 overflow-x-hidden">
    
    <Header /> 
    <main class="max-w-6xl mx-auto p-8 mt-20 space-y-32 animar-entrada">
      
    <Hero />

	<SobreMi />

    <!-- SECCIÓN: TRAYECTORIA -->
	<section id="trayectoria" class="scroll-mt-24">
		<h2 class="text-3xl font-bold text-white mb-8 border-b border-gray-800 pb-4">Trayectoria</h2>
			
		<!-- Línea de tiempo visual -->
		<div class="border-l-2 border-orange-400/50 pl-6 space-y-10 ml-2">
			
		<!-- Hito 1: Cívica -->
		<div class="relative">
			<div class="absolute -left-[31px] top-1.5 w-4 h-4 bg-orange-400 rounded-full"></div>
			<h3 class="text-xl font-semibold text-white">Seleccionado - Data Engineer</h3>
			<span class="text-sm font-mono text-orange-300">Cívica Software | Próxima incorporación</span>
			<p class="mt-3 text-gray-400 leading-relaxed">
			Seleccionado para formar parte de la empresa, a la espera de formalizar la contratación. En paralelo, continúo mi especialización tecnológica a través del <em>Education Programme - Data Engineering</em> de la compañía.
			</p>
		</div>

		<!-- Hito 2: Zaitec -->
		<div class="relative">
			<div class="absolute -left-[31px] top-1.5 w-4 h-4 bg-gray-600 rounded-full"></div>
			<h3 class="text-xl font-semibold text-white">Desarrollador Web (FFE)</h3>
			<span class="text-sm font-mono text-gray-400">Zaitec Innova | Actualidad</span>
			<p class="mt-3 text-gray-400 leading-relaxed">
			Realizando la Fase de Formación en Empresa (FFE) integrado en el equipo de desarrollo, aplicando arquitecturas y metodologías en proyectos reales.
			</p>
		</div>

		</div>
		
		<Stack />

		<section id="proyectos" class="scroll-mt-24">
			<h2 class="text-3xl font-bold text-white mb-8 border-b border-gray-800 pb-4">Proyectos Destacados</h2>
			
			<div class="grid grid-cols-1 gap-8">
			
			<ProyectoCard 
				titulo="Gestfincas"
				descripcion="Aplicación de gestión integral de propiedades desarrollada en equipo..."
				etiquetas={["Full-Stack", "JavaScript", "Reportes PDF", "Foros"]}
				linkRepo="https://github.com/Btncr13/gestfincas"
				imagen="/tu-imagen-gestfincas.jpg" 
			/>

			<ProyectoCard 
				titulo="Pipeline Rescue-Animal"
				descripcion="Diseño e implementación de una pipeline de datos end-to-end..."
				etiquetas={["Python", "Snowflake", "dbt", "Power BI", "SQL"]}
				linkRepo="https://github.com/Btncr13/pipeline-rescue"
				imagen="/arquitectura.webp" 
			/>

			<ProyectoCard 
				titulo="Drop 5: E-commerce"
				descripcion="Plataforma de ventas Flash con control de stock crítico..."
				etiquetas={["PHP", "CSS", "MariaDB", "JavaScript"]}
				linkRepo="https://github.com/Btncr13/tienda_enfoque"
				imagen="/tienda.webp" 
			/>
			
			</div>
		</section>
		</main>

	<footer class="max-w-6xl mx-auto px-8 py-12 border-t border-gray-800 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-gray-500 text-sm">
          © {new Date().getFullYear()} Tu Nombre. Casi todos los derechos reservados.
        </p>
        
        <div class="flex gap-6">
          <a href="https://github.com/Btncr13" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">
            <span class="sr-only">GitHub</span>
            <img src="https://api.iconify.design/simple-icons:github.svg?color=%236b7280" class="w-6 h-6 hover:opacity-80 transition-opacity" alt="GitHub" />
          </a>
          <a href="https://www.linkedin.com/in/cesarbetancorcano/" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors">
            <span class="sr-only">LinkedIn</span>
            <img src="https://api.iconify.design/simple-icons:linkedin.svg?color=%236b7280" class="w-6 h-6 hover:opacity-80 transition-opacity" alt="LinkedIn" />
          </a>
        </div>
      </footer>

  </body>
</html>