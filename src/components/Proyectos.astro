---
import ProyectoCard from './ProyectoCard.astro';
---

<section id="proyectos" class="py-24 max-w-6xl mx-auto scroll-mt-24">
  
  <div class="mb-12 flex flex-col md:flex-row md:items-end justify-between gap-4 border-b border-gray-800 pb-6">
    <div>
      <span class="text-cyan-400 font-mono text-sm tracking-widest uppercase">03 / Proyectos</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-2">Proyectos Destacados</h2>
    </div>
    <div class="text-gray-500 font-mono text-sm mb-2">
      [ 3 proyectos ]
    </div>
  </div>
 
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
    <ProyectoCard 
      titulo="Gestfincas"
      descripcion="Aplicación integral para la administración de comunidades. Automatiza cobros, generación de reportes y mejora la comunicación entre vecinos."
      etiquetas={[
        { nombre: "JavaScript", color: "f7df1e" },
        { nombre: "MySQL", color: "e38c00" },
        { nombre: "HTML", color: "e34f26" },
        { nombre: "Bootstrap", color: "7952b3" },
        { nombre: "XAMPP", color: "fb7a24" }
      ]}
      linkRepo="https://github.com/Btncr13/gestfincas"
      imagen="/gestfincas.jpg" 
      colorAcento="#38bdf8"
    />

    <ProyectoCard 
      titulo="Pipeline Rescue-Animal"
      descripcion="Diseño e implementación de una pipeline de datos end-to-end. Extracción, transformación y carga (ELT) automatizada para análisis de negocio."
      etiquetas={[
        { nombre: "Python", color: "3776ab" },
        { nombre: "Snowflake", color: "29b5e8" },
        { nombre: "dbt", color: "ff694b" },
        { nombre: "Power BI", color: "f2c811" },
        { nombre: "SQL", color: "e38c00" }
      ]}
      linkRepo="https://github.com/Btncr13/pipeline-rescue"
      imagen="/pipeline.webp" 
      colorAcento="#f89820"
    />

    <ProyectoCard 
      titulo="Drop 5: E-commerce"
      descripcion="Plataforma de ventas 'Flash' con control de stock crítico. Desarrollo Full Stack enfocado en rendimiento, seguridad y conversión de usuario."
      etiquetas={[
        { nombre: "PHP", color: "777bb4" },
        { nombre: "CSS", color: "1572b6" },
        { nombre: "MariaDB", color: "c0765a" },
        { nombre: "JavaScript", color: "f7df1e" },
        { nombre: "HTML", color: "e34f26" },
        { nombre: "SQL", color: "e38c00" }
      ]}
      linkRepo="https://github.com/Btncr13/tienda_enfoque"
      imagen="/drop5.webp" 
      colorAcento="#c084fc"
    />

  </div>
</section>