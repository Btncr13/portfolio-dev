---
const { nombre, icono, colorHex } = Astro.props;
const urlIcono = `https://api.iconify.design/simple-icons:${icono}.svg?color=%23${colorHex}`;

const clasesTarjeta = [
  "w-full flex items-center gap-3 p-2.5 cursor-default group",
  "rounded-lg bg-gray-900/50 border border-gray-800 transition-all duration-300",
  "hover:bg-[color-mix(in_srgb,var(--brand-color)_10%,transparent)]",
  "hover:border-[color-mix(in_srgb,var(--brand-color)_40%,transparent)]",
  "hover:shadow-[0_0_15px_color-mix(in_srgb,var(--brand-color)_15%,transparent)]"
].join(" ");
---

<div class={clasesTarjeta} style={`--brand-color: #${colorHex};`}>
  <img src={urlIcono} class="w-6 h-6 shrink-0 group-hover:scale-110 transition-transform duration-300" alt={nombre} />
  <span class="text-gray-400 group-hover:text-gray-100 font-mono font-medium text-sm truncate transition-colors duration-300">{nombre}</span>
</div>