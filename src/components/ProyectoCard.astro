---
interface Etiqueta {
  nombre: string;
  color: string;
}

interface Props {
  titulo: string;
  descripcion: string;
  etiquetas: Etiqueta[];
  linkRepo: string;
  imagen: string;
  colorAcento?: string;
}

const { titulo, descripcion, etiquetas, linkRepo, imagen, colorAcento = "#38bdf8" } = Astro.props;

const cardClasses = [
  "group relative flex flex-col bg-gray-900/40 rounded-xl border border-gray-800",
  "overflow-hidden transition-all duration-500",
  "hover:-translate-y-2 hover:scale-[1.02]",
  "hover:bg-[color-mix(in_srgb,var(--accent)_5%,transparent)]",
  "hover:border-[color-mix(in_srgb,var(--accent)_50%,transparent)]",
  "hover:shadow-[0_8px_30px_color-mix(in_srgb,var(--accent)_15%,transparent)]"
].join(" ");
---

<article class={cardClasses} style={`--accent: ${colorAcento};`}>
  
  <!-- Imagen Superior -->
  <div class="relative h-48 w-full overflow-hidden shrink-0">
    <img 
      src={imagen} 
      alt={`Captura de ${titulo}`} 
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" 
    />
    
    <!-- Degradado inferior para integrar con la tarjeta -->
    <div class="absolute inset-0 bg-linear-to-t from-gray-900 via-gray-900/20 to-transparent"></div>
  </div>

  <!-- Contenido Inferior -->
  <div class="p-6 flex flex-col grow z-10">
    <h3 class="text-xl font-bold text-white mb-2 group-hover:text-(--accent) transition-colors duration-300">{titulo}</h3>
    <p class="text-gray-400 text-sm mb-6 leading-relaxed line-clamp-3">
      {descripcion}
    </p>
    
    <div class="flex flex-wrap gap-2 mt-auto mb-6">
      {etiquetas.map((etiqueta) => (
        <span class="font-mono px-2 py-1 rounded text-xs border" style={`color: #${etiqueta.color}; border-color: color-mix(in srgb, #${etiqueta.color} 30%, transparent); background-color: color-mix(in srgb, #${etiqueta.color} 10%, transparent);`}>
          {etiqueta.nombre}
        </span>
      ))}
    </div>
    
    <!-- Botón Link -->
    <div class="mt-auto">
      <a href={linkRepo} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm font-mono font-medium text-gray-400 hover:text-white transition-colors group/link">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 group-hover/link:text-(--accent) transition-colors" viewBox="0 0 24 24" fill="currentColor">
          <path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.831.092-.646.35-1.086.636-1.336-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.114 2.504.336 1.909-1.294 2.747-1.025 2.747-1.025.546 1.379.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"></path>
        </svg>
        Ver Repositorio
      </a>
    </div>
  </div>
  
</article>