---
---

<section id="contacto" class="py-24 scroll-mt-24">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-start">

    <!-- Columna Izquierda: Texto e Info -->
    <div>
      <span class="text-cyan-400 font-mono text-sm tracking-widest uppercase">06 / Contacto</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-6">
        Construyamos algo <span class="text-blue-400">juntos</span>
      </h2>
      <p class="text-gray-400 text-lg leading-relaxed mb-12">
        ¿Tienes un proyecto, una oportunidad o simplemente quieres hablar de datos? Escríbeme y te respondo en menos de 24 horas.
      </p>

      <div class="space-y-6">
        <div class="flex items-center border-b border-gray-800/50 pb-4 group">
          <span class="font-mono text-gray-500 text-sm w-28 shrink-0 group-hover:text-gray-400 transition-colors">Email</span>
          <a href="mailto:betancor13@gmail.com" class="text-gray-300 hover:text-cyan-400 transition-colors text-base font-medium truncate">
            betancor13@gmail.com
          </a>
        </div>
        <div class="flex items-center border-b border-gray-800/50 pb-4 group">
          <span class="font-mono text-gray-500 text-sm w-28 shrink-0 group-hover:text-gray-400 transition-colors">LinkedIn</span>
          <a href="https://linkedin.com/in/cesarbetancorcano" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-cyan-400 transition-colors text-base font-medium truncate">
            /in/cesarbetancorcano
          </a>
        </div>
        <div class="flex items-center border-b border-gray-800/50 pb-4 group">
          <span class="font-mono text-gray-500 text-sm w-28 shrink-0 group-hover:text-gray-400 transition-colors">GitHub</span>
          <a href="https://github.com/Btncr13" target="_blank" rel="noopener noreferrer" class="text-gray-300 hover:text-cyan-400 transition-colors text-base font-medium truncate">
            github.com/Btncr13
          </a>
        </div>
      </div>
    </div>

    <!-- Columna Derecha: Formulario -->
    <div class="bg-gray-900/40 border border-gray-800 p-8 rounded-xl shadow-2xl shadow-black/50">
      <form id="contact-form" class="space-y-6">
        
        <div id="success-message" class="hidden bg-cyan-950/30 border border-cyan-500/50 text-cyan-300 px-4 py-3 rounded-lg text-sm font-medium transition-all">
          ¡Mensaje enviado! Te responderé en menos de 24 horas.
        </div>

        <div>
          <label for="nombre" class="block text-xs font-mono text-gray-500 mb-2 uppercase tracking-wide">Nombre</label>
          <input type="text" id="nombre" name="nombre" required class="w-full bg-gray-950/50 border border-gray-800 rounded-lg px-4 py-3 text-white placeholder-gray-700 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all duration-300" placeholder="Tu nombre">
        </div>

        <div>
          <label for="email" class="block text-xs font-mono text-gray-500 mb-2 uppercase tracking-wide">Email</label>
          <input type="email" id="email" name="email" required class="w-full bg-gray-950/50 border border-gray-800 rounded-lg px-4 py-3 text-white placeholder-gray-700 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all duration-300" placeholder="tu@email.com">
        </div>

        <div>
          <label for="mensaje" class="block text-xs font-mono text-gray-500 mb-2 uppercase tracking-wide">Mensaje</label>
          <textarea id="mensaje" name="mensaje" rows="4" required class="w-full bg-gray-950/50 border border-gray-800 rounded-lg px-4 py-3 text-white placeholder-gray-700 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all duration-300 resize-none" placeholder="Hola, te escribo para..."></textarea>
        </div>

        <button type="submit" class="w-full inline-flex justify-center items-center gap-2 font-bold py-3.5 px-6 rounded-lg transition-all duration-300 border border-orange-500 bg-orange-500 hover:bg-orange-400 text-gray-900 hover:-translate-y-1 hover:shadow-[0_8px_20px_-8px_rgba(249,115,22,0.6)]">
          Enviar mensaje
        </button>
      </form>
    </div>

  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-message');

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      
      if (successMsg) {
        successMsg.classList.remove('hidden');
        form.reset();
        
        setTimeout(() => {
          successMsg.classList.add('hidden');
        }, 5000);
      }
    });
  }
</script>