---
---

<section id="trayectoria" class="relative w-screen left-1/2 -translate-x-1/2 bg-gray-900/30 border-y border-gray-800 py-24 scroll-mt-24">
  <div class="max-w-6xl mx-auto px-8">
    
    <!-- ENCABEZADO DE LA SECCIÓN -->
    <div class="mb-20">
      <span class="text-cyan-400 font-mono text-sm tracking-widest uppercase">04 / Trayectoria</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-6">Experiencia y Formación</h2>
      <p class="text-gray-400 text-lg leading-relaxed max-w-3xl">
        De encargado general a Data Engineer. 16 años liderando equipos me dieron la constancia y la responsabilidad; el reciclaje en tecnología —y el curso de Data Engineering de Cívica— me han llevado a incorporarme a su equipo en 2026.
      </p>
    </div>
      
    <!-- BLOQUE 1 — Experiencia profesional -->
    <div class="mb-24">
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Experiencia profesional</h3><br>
      
      <div class="relative max-w-4xl mx-auto">
        <!-- Línea vertical degradada -->
        <div class="absolute left-2.75 md:left-49.75 top-2 bottom-0 w-0.5 bg-linear-to-b from-cyan-400 via-gray-800 to-transparent"></div>

        <div class="flex flex-col gap-12">
          
          <!-- 1. Cívica Software (Destacado) -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-cyan-400">2026 (Julio ->)</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <!-- Punto destacada -->
            <div class="absolute left-1 md:left-48 top-2 w-4 h-4 rounded-full bg-cyan-400 shadow-[0_0_12px_rgba(34,211,238,0.7)] ring-4 ring-cyan-400/20 z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-2">
                <div class="w-8 h-8 rounded bg-cyan-950 border border-cyan-800 flex items-center justify-center font-bold text-cyan-400 shrink-0">C</div>
                <span class="font-semibold text-cyan-400 text-lg">Cívica Software</span>
                <span class="bg-cyan-400/10 text-cyan-300 border border-cyan-400/20 px-2 py-0.5 rounded text-[10px] font-bold font-mono uppercase tracking-wider">Próximamente</span>
              </div>
              <h4 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-wide">Data Engineer</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Mi incorporación al equipo de Cívica como Data Engineer, fruto directo de la formación que cursé con ellos.
              </p>
            </div>
          </div>

          <!-- 2. Zaitec Innova -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">Mar 2026 - Jun 2026</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Remoto</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-2">
                <div class="w-8 h-8 rounded bg-gray-800 border border-gray-700 flex items-center justify-center font-bold text-gray-300 shrink-0">Z</div>
                <span class="font-semibold text-gray-300 text-lg">Zaitec Innova</span>
              </div>
              <h4 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-wide">Desarrollador Web (Prácticas)</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Desarrollo de aplicaciones web en remoto durante las prácticas del grado DAW, trabajando en equipo.
              </p>
            </div>
          </div>

          <!-- 3. TM Digital Granada -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">Oct 2023 - Feb 2024</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-2">
                <div class="w-8 h-8 rounded bg-gray-800 border border-gray-700 flex items-center justify-center font-bold text-gray-300 shrink-0">T</div>
                <span class="font-semibold text-gray-300 text-lg">TM Digital Granada</span>
              </div>
              <h4 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-wide">Técnico de Redes (Prácticas)</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                Prácticas del grado SMR como informático de redes; me ofrecieron quedarme pero preferí seguir formándome.
              </p>
            </div>
          </div>

          <!-- 4. Capifer Granada -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">2006 - 2022</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex flex-wrap items-center gap-x-3 gap-y-2 mb-2">
                <div class="w-8 h-8 rounded bg-gray-800 border border-gray-700 flex items-center justify-center font-bold text-gray-300 shrink-0">C</div>
                <span class="font-semibold text-gray-300 text-lg">Capifer Granada S.L.</span>
              </div>
              <h4 class="text-xl md:text-2xl font-bold text-white mb-2 tracking-wide">Encargado General</h4>
              <p class="text-gray-400 text-sm leading-relaxed">
                16 años creciendo en la empresa hasta dirigir el día a día como Encargado General: liderazgo, gestión de equipos y responsabilidad operativa.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- BLOQUE 2 — Formación reglada -->
    <div class="mb-24">
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Formación</h3><br>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Card 1: Destacada (Cívica) -->
        <div class="bg-cyan-950/20 border border-cyan-500/40 rounded-xl p-6 relative overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
          <div class="flex items-center gap-3 mb-4 mt-2">
            <div class="w-10 h-10 rounded bg-cyan-900 border border-cyan-700 flex items-center justify-center font-bold text-cyan-300 shrink-0">C</div>
            <div>
              <span class="block text-cyan-300 font-semibold text-sm">Cívica Software · UGR</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2024 - 2026</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-cyan-400 transition-colors">Curso de Data Engineering</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Formación intensiva en ingeniería de datos por las tardes; modelado de datos, dbt y Snowflake. El curso que me abrió las puertas para entrar en Cívica.
          </p>
        </div>

        <!-- Card 2: MEDAC DAW -->
        <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-6 hover:-translate-y-1 transition-transform duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded bg-orange-950/50 border border-orange-800/50 flex items-center justify-center font-bold text-orange-400 shrink-0">M</div>
            <div>
              <span class="block text-orange-400 font-semibold text-sm">Instituto MEDAC · Granada</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2024 - 2026</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-orange-400 transition-colors">Grado Superior en Desarrollo de Aplicaciones Web (DAW)</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Formación full-stack en desarrollo web. La base que me convirtió en desarrollador.
          </p>
        </div>

        <!-- Card 3: MEDAC SMR -->
        <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-6 hover:-translate-y-1 transition-transform duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded bg-orange-950/50 border border-orange-800/50 flex items-center justify-center font-bold text-orange-400 shrink-0">M</div>
            <div>
              <span class="block text-orange-400 font-semibold text-sm">Instituto MEDAC · Granada</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2022 - 2024</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-orange-400 transition-colors">Grado Medio en Sistemas Microinformáticos y Redes (SMR)</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Base sólida en sistemas, hardware y redes. El punto de partida de mi cambio hacia la tecnología.
          </p>
        </div>

      </div>
    </div>

    <!-- BLOQUE 3 — Formación complementaria -->
    <div>
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Formación complementaria</h3><br>
      <div class="flex flex-wrap items-center gap-3">
        
        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">Fundamentos de Inteligencia Artificial</span>
          <span class="text-gray-500 font-mono text-xs">2025</span>
        </div>

        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">Prompt Engineering con LLMs</span>
          <span class="text-gray-500 font-mono text-xs">2025</span>
        </div>

        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">IA Generativa Aplicada</span>
          <span class="text-gray-500 font-mono text-xs">2026</span>
        </div>

      </div>
    </div>

  </div>
</section>