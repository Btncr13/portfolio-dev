---
---

<section id="trayectoria" class="relative w-screen left-1/2 -translate-x-1/2 bg-gray-900/30 border-y border-gray-800 py-24 scroll-mt-24">
  <div class="max-w-6xl mx-auto px-8">
    
    <!-- ENCABEZADO DE LA SECCIÓN -->
    <div class="mb-20">
      <span class="text-cyan-400 font-mono text-sm tracking-widest uppercase">04 / Trayectoria</span>
      <h2 class="text-4xl md:text-5xl font-bold text-white mt-2 mb-6">Experiencia y Formación</h2>
      <p class="text-gray-400 text-lg leading-relaxed max-w-2xl">
        Un recorrido por mi evolución profesional y la formación que respalda mis habilidades técnicas.
      </p>
    </div>
      
    <!-- BLOQUE 1 — Experiencia profesional -->
    <div>
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Experiencia profesional</h3><br>
      
      <div class="relative max-w-4xl mx-auto">
        <!-- Línea vertical degradada -->
        <div class="absolute left-2.75 md:left-49.75 top-2 bottom-0 w-0.5 bg-linear-to-b from-cyan-400 via-gray-800 to-transparent"></div>

        <div class="flex flex-col gap-12">
          
          <!-- 1. Cívica Software (Destacado) -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-cyan-400">2026 (Noviembre ->)</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <!-- Punto destacada -->
            <div class="absolute left-1 md:left-48 top-2 w-4 h-4 rounded-full bg-cyan-400 shadow-[0_0_12px_rgba(34,211,238,0.7)] ring-4 ring-cyan-400/20 z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex items-center gap-4 mb-4">
                <img src="/portfolio-dev/civicalogo.jpg" alt="Logo Cívica Software" class="w-12 h-12 md:w-14 md:h-14 rounded-lg bg-cyan-950 border border-cyan-800 p-1.5 object-contain shrink-0" />
                <div class="flex flex-col justify-center">
                  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-1">
                    <a href="https://civica-soft.com/" target="_blank" rel="noopener noreferrer" class="font-semibold text-cyan-400 text-lg hover:text-cyan-300 hover:underline decoration-cyan-400/50 underline-offset-4 transition-all">
                      Cívica Software
                    </a>
                    <span class="bg-cyan-400/10 text-cyan-300 border border-cyan-400/20 px-2 py-0.5 rounded text-[10px] font-bold font-mono uppercase tracking-wider">Próximamente</span>
                  </div>
                  <h4 class="text-xl md:text-2xl font-bold text-white tracking-wide">Data Engineer</h4>
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Incorporación al equipo de Cívica-Soft como Data Engineer.
              </p>
            </div>
          </div>

          <!-- 2. Zaitec Innova -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">Mar 2026 - Jun 2026</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Remoto</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex items-center gap-4 mb-4">
                <img src="/portfolio-dev/zaitec.jpg" alt="Logo Zaitec Innova" class="w-12 h-12 md:w-14 md:h-14 rounded-lg bg-gray-800 border border-gray-700 p-1.5 object-contain shrink-0" />
                <div class="flex flex-col justify-center">
                  <a href="https://zaitecinnova.com/" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-300 text-lg mb-1 hover:text-cyan-400 hover:underline decoration-cyan-400/50 underline-offset-4 transition-all">
                    Zaitec Innova
                  </a>
                  <h4 class="text-xl md:text-2xl font-bold text-white tracking-wide">Desarrollador Web (Prácticas)</h4>
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Miembro de un equipo como desarrollador Full-Stack durante las prácticas del grado de Desarrollo de Aplicaciones Web.
              </p>
            </div>
          </div>

          <!-- 3. TM Digital Granada -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">Oct 2023 - Feb 2024</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex items-center gap-4 mb-4">
                <img src="/portfolio-dev/tmdigital.jpg" alt="Logo TM Digital Granada" class="w-12 h-12 md:w-14 md:h-14 rounded-lg bg-gray-800 border border-gray-700 p-1.5 object-contain shrink-0" />
                <div class="flex flex-col justify-center">
                  <a href="https://tmdigital.es/" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-300 text-lg mb-1 hover:text-cyan-400 hover:underline decoration-cyan-400/50 underline-offset-4 transition-all">
                    TM Digital Granada
                  </a>
                  <h4 class="text-xl md:text-2xl font-bold text-white tracking-wide">Técnico de Redes (Prácticas)</h4>
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                Tecnico informático de redes durante las prácticas del grado de Sistemas Microinformáticos y Redes.
              </p>
            </div>
          </div>

          <!-- 4. Capifer Granada -->
          <div class="relative pl-12 md:pl-0 flex flex-col md:flex-row gap-2 md:gap-20 group">
            <div class="md:w-40 shrink-0 md:text-right pt-1.5 flex flex-col">
              <span class="font-mono text-sm font-medium text-gray-500">2006 - 2022</span>
              <span class="font-mono text-xs text-gray-500 mt-1">Granada</span>
            </div>
            <div class="absolute left-1.75 md:left-48.75 top-2.5 w-2.5 h-2.5 rounded-full bg-gray-600 group-hover:bg-gray-400 transition-colors z-10"></div>
            <div class="md:flex-1 pb-2">
              <div class="flex items-center gap-4 mb-4">
                <img src="/portfolio-dev/capifer.png" alt="Logo Capifer Granada S.L." class="w-12 h-12 md:w-14 md:h-14 rounded-lg bg-gray-800 border border-gray-700 p-1.5 object-contain shrink-0" />
                <div class="flex flex-col justify-center">
                  <a href="https://capifer.com/" target="_blank" rel="noopener noreferrer" class="font-semibold text-gray-300 text-lg mb-1 hover:text-cyan-400 hover:underline decoration-cyan-400/50 underline-offset-4 transition-all">
                    Capifer Granada S.L.
                  </a>
                  <h4 class="text-xl md:text-2xl font-bold text-white tracking-wide">Encargado General</h4>
                </div>
              </div>
              <p class="text-gray-400 text-sm leading-relaxed">
                16 años creciendo en la empresa hasta dirigir el día a día como Encargado General: liderazgo, gestión de equipos y responsabilidad operativa.
              </p>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- Línea de separación -->
    <div class="my-20 border-t border-gray-800/80"></div>

    <!-- BLOQUE 2 — Formación reglada -->
    <div class="mb-24">
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Formación</h3><br>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Card 1: Destacada (Cívica) -->
        <div class="bg-cyan-950/20 border border-cyan-500/40 rounded-xl p-6 relative overflow-hidden group hover:-translate-y-1 transition-transform duration-300">
          <div class="flex items-center gap-3 mb-4 mt-2">
            <img src="/portfolio-dev/civicalogo.jpg" alt="Logo Cívica Software" class="w-12 h-12 rounded bg-cyan-900 border border-cyan-700 p-0 object-contain shrink-0" />
            <div>
              <span class="block text-cyan-300 font-semibold text-sm">Cívica Software · UGR</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2024 - 2026</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-cyan-400 transition-colors">Curso de Data Engineering</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Formación centrada en la ingeniería de datos; Fundamentos básicos, modelado de datos, dbt, Snowflake, BigQuery, SQL y Power BI.
          </p>
        </div>

        <!-- Card 2: MEDAC DAW -->
        <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-6 hover:-translate-y-1 transition-transform duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <img src="/portfolio-dev/medaclogo.jpg" alt="Logo Instituto MEDAC" class="w-12 h-12 rounded bg-orange-950/50 border border-gray-800/50 p-0 object-contain shrink-0" />
            <div>
              <span class="block text-orange-400 font-semibold text-sm">Instituto MEDAC · Granada</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2024 - 2026</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-orange-400 transition-colors">Grado Superior en Desarrollo de Aplicaciones Web (DAW)</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Formación full-stack en desarrollo de aplicaciones web.
          </p>
        </div>

        <!-- Card 3: MEDAC SMR -->
        <div class="bg-gray-950/40 border border-gray-800 rounded-xl p-6 hover:-translate-y-1 transition-transform duration-300 group">
          <div class="flex items-center gap-3 mb-4">
            <img src="/portfolio-dev/medaclogo.jpg" alt="Logo Instituto MEDAC" class="w-12 h-12 rounded bg-orange-950/50 border border-gray-800/50 p-0 object-contain shrink-0" />
            <div>
              <span class="block text-orange-400 font-semibold text-sm">Instituto MEDAC · Granada</span>
              <span class="block text-gray-400 font-mono text-xs mt-0.5">2022 - 2024</span>
            </div>
          </div>
          <h4 class="text-xl font-bold text-white mb-3 group-hover:text-orange-400 transition-colors">Grado Medio en Sistemas Microinformáticos y Redes (SMR)</h4>
          <p class="text-gray-400 text-sm leading-relaxed">
            Base sólida en sistemas, hardware y redes.
          </p>
        </div>

      </div>
    </div>

    <!-- BLOQUE 3 — Formación complementaria -->
    <div>
      <h3 class="text-cyan-400 font-mono text-sm tracking-widest uppercase">Formación complementaria</h3><br>
      <div class="flex flex-wrap items-center gap-3">
        
        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">Data Science con IA</span>
          <span class="text-gray-500 font-mono text-xs">2026</span>
        </div>
        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">Desarrollo con IA: De 0 a producción</span>
          <span class="text-gray-500 font-mono text-xs">2026</span>
        </div>
        <div class="px-4 py-2 rounded-full border border-gray-700/50 bg-gray-800/40 flex items-center gap-3 hover:bg-gray-700/50 transition-colors cursor-default group">
          <span class="text-gray-400 text-sm font-medium group-hover:text-gray-200 transition-colors">Iniciación al Desarrollo con IA</span>
          <span class="text-gray-500 font-mono text-xs">2025</span>
        </div>

      </div>
    </div>

  </div>
</section>