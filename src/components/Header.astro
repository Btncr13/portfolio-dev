---
import { Icon } from 'astro-icon/components';
import BotonContacto from './BotonContacto.astro';

const navLinks = [
  { nombre: 'Inicio', url: '#' },
  { nombre: 'Sobre mí', url: '#sobre-mi' },
  { nombre: 'Stack', url: '#stack' },
  { nombre: 'Proyectos', url: '#proyectos' },
  { nombre: 'Trayectoria', url: '#trayectoria' }
];
---

<header id="main-header" class="fixed top-0 left-0 z-50 w-full transition-all duration-300 h-20 flex items-center border-b border-transparent">
  <div class="w-full max-w-6xl mx-auto flex items-center justify-between px-8">
    
    <a href="#" class="flex items-center gap-3 group">
      <div class="w-10 h-10 rounded-lg bg-linear-to-tr from-blue-500 to-cyan-400 flex items-center justify-center font-mono font-bold text-white shadow-lg">
        CB
      </div>
      <span class="font-mono text-cyan-400 tracking-[0.2em] font-medium hidden sm:block">CESAR.DEV</span>
    </a>

    <nav class="flex items-center gap-6">
      <ul class="hidden md:flex gap-1 font-sans font-medium text-sm text-gray-400">
        {navLinks.map((link) => (
          <li>
            <a href={link.url} class="px-4 py-2 rounded-md hover:bg-gray-800/50 hover:text-white transition-all duration-200">{link.nombre}</a>
          </li>
        ))}
      </ul>

      <div class="hidden sm:flex gap-2 border-l border-gray-800 pl-6 ml-2">
        <a href="https://github.com/Btncr13" target="_blank" rel="noopener noreferrer" aria-label="Perfil de GitHub" class="p-2 text-gray-400 hover:text-cyan-400 hover:bg-gray-800/50 rounded-md transition-all">
          <Icon name="simple-icons:github" class="w-5 h-5" />
        </a>
        <a href="https://www.linkedin.com/in/cesarbetancorcano/" target="_blank" rel="noopener noreferrer" aria-label="Perfil de LinkedIn" class="p-2 text-gray-400 hover:text-cyan-400 hover:bg-gray-800/50 rounded-md transition-all">
          <Icon name="simple-icons:linkedin" class="w-5 h-5" />
        </a>
      </div>

      <div class="ml-4">
        <BotonContacto
          texto="Contactar"
          link="mailto:betancor13@gmail.com"
          icono="lucide:mail"
          variante="primario"
        />
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.getElementById('main-header');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('bg-gray-950/80', 'backdrop-blur-md', 'border-gray-800');
    } else {
      header?.classList.remove('bg-gray-950/80', 'backdrop-blur-md', 'border-gray-800');
    }
  });
</script>